# LLM API (Fallback chain: Gemini → Groq → Ollama)
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=gemini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Blockchain (Fallback chain: Base → Arbitrum)
PRIVATE_KEY=your_testnet_private_key_here
BASE_RPC_URL=https://sepolia.base.org
BASE_CONTRACT_ADDRESS=deployed_contract_address_here
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_CONTRACT_ADDRESS=optional_backup_contract_here

# Storage (Fallback chain: Arweave → IPFS/Pinata)
ARWEAVE_WALLET_PATH=./arweave-wallet.json
ARWEAVE_GATEWAY=https://arweave.net
PINATA_API_KEY=optional_pinata_key_here
PINATA_SECRET_KEY=optional_pinata_secret_here
# Arweave encryption key — AES-256-GCM (REQUIRED for privacy — memories are public on-chain without this)
# Generate: python -c "import os; print(os.urandom(32).hex())"
IMP_ARWEAVE_ENCRYPTION_KEY=your_64_hex_char_key_here

# Cognitio Configuration
MAX_ACTIVE_MEMORIES=10000
PRUNE_INTERVAL_HOURS=24
CHECKPOINT_EVERY_N_MESSAGES=5
CHECKPOINT_INTERVAL_MINUTES=10
REALITY_CHECK_ENABLED=true
EMOTION_SHIELD_ENABLED=true

# Kill Switch (optional — either one is sufficient)
# Option A — plain-text (engine auto-hashes with PBKDF2):
# IMP_KILL_SWITCH=plain_text_passphrase_here
#
# Option B — pre-hashed (recommended):
# WARNING: IMP_KILL_SWITCH_HASH must be a PBKDF2-HMAC-SHA256 hash, NOT plain SHA-256.
# Generate with:
#   python -c "import hashlib; print(hashlib.pbkdf2_hmac('sha256', b'yourpassphrase', b'IMP-kill-switch-salt-v1', 100_000).hex())"
# IMP_KILL_SWITCH_HASH=pbkdf2_hmac_sha256_hex_here

# Admin Freeze (optional — for SaaS admin panel)
# IMP_ADMIN_KEY_HASH=sha256_hex_of_your_admin_passphrase

# General
DEBUG=true
MEMORY_FILE=data/memories.json
WORKING_MEMORY_DB=data/working_memory.db
CHROMA_DB_DIR=data/chroma_db
